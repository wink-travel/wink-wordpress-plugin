{
    "name": "wink/wink-wordpress-plugin",
    "description": "Wink Affiliate WordPress Plugin",
    "type": "wordpress-plugin",
    "license": "GPL-3.0",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload-dev": {
        "psr-4": {
            "Wink\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
